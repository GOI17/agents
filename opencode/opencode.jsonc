{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "github-copilot"
  ],
  "experimental": {
    "disable_paste_summary": true
  },
  "mcp": {
    "engram": {
      "command": [
        "/opt/homebrew/Cellar/engram/1.15.15/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "playwright": {
      "command": [
        "npx",
        "@playwright/mcp@0.0.75"
      ],
      "enabled": true,
      "type": "local"
    },
    "remotion-documentation": {
      "command": [
        "npx",
        "@remotion/mcp@4.0.462"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "plugin": [
    "opencode-subagent-statusline"
  ]
}
